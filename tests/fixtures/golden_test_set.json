  "description": "Golden eval dataset converted for the current EvalRunner schema.",
  "cases": [
    {
      "case_id": "golden_001",
      "query": "What is Modular RAG?",
      "tags": ["golden", "overview", "english"],
      "expected_keywords": ["Modular RAG", "modular", "pluggable", "components"],
      "expected_answer": "Modular RAG is a RAG system with modular, pluggable components."
    },
    {
      "case_id": "golden_002",
      "query": "How to configure Azure OpenAI?",
      "tags": ["golden", "provider", "azure"],
      "expected_keywords": [
        "Azure OpenAI",
        "deployment_name",
        "azure_endpoint",
        "api_version",
        "api_key"
      ],
      "expected_answer": "Configure Azure OpenAI with deployment_name, endpoint, version, and key."
    },
    {
      "case_id": "golden_003",
      "query": "What is hybrid search and how does it work?",
      "tags": ["golden", "retrieval", "hybrid"],
      "expected_keywords": ["dense", "sparse", "BM25", "RRF", "hybrid"],
      "expected_answer": "Hybrid search combines dense and sparse retrieval, then fuses them."
    },
    {
      "case_id": "golden_004",
      "query": "Explain the chunking strategy",
      "tags": ["golden", "ingestion", "chunking"],
      "expected_keywords": ["chunk", "chunking", "recursive", "metadata"],
      "expected_answer": "Documents are split into chunks, then refined and enriched with metadata."
    },
    {
      "case_id": "golden_005",
      "query": "What evaluation metrics are supported?",
      "tags": ["golden", "evaluation", "metrics"],
      "expected_keywords": ["hit_rate", "MRR", "faithfulness", "answer_relevancy", "Ragas"],
      "expected_answer": "The system supports hit_rate, MRR, faithfulness, and answer relevancy."
